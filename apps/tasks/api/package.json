    "@suite/domain-tasks": "workspace:*",
    "@suite/env-config": "workspace:*",
    "@suite/shared-kernel": "workspace:*",
    "hono": "^4.11.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.8.0",
    "vitest": "catalog:",
    "wrangler": "^4.0.0"
  }
}
