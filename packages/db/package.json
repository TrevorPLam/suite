    "db:migrate:tasks": "APP_DOMAIN=tasks tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@suite/shared-kernel": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "catalog:",
    "vitest": "catalog:"
  }
}
