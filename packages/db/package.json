{
  "name": "@suite/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:run": "vitest run",
    "lint": "eslint src",
    "drizzle-kit": "drizzle-kit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:calendar": "APP_DOMAIN=calendar tsx scripts/migrate.ts",
