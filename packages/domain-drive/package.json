{
  "name": "@suite/domain-drive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "db:generate": "drizzle-kit generate --config=../../packages/db/drizzle.drive.config.ts",
    "db:migrate": "APP_DOMAIN=drive tsx ../../packages/db/scripts/migrate.ts"
  },
  "dependencies": {
    "@suite/crypto": "workspace:*",
    "@suite/db": "workspace:*",
    "@suite/shared-kernel": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "vitest": "catalog:"
  }
}
