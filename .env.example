# Database connection string for PostgreSQL
# Required for running migrations and database operations
DATABASE_URL=postgresql://localhost:5432/suite

# Better Auth secret for session encryption and signing
# Required for authentication to work
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Better Auth base URL for authentication callbacks
# Required for authentication to work
# Set to your production domain in production, e.g., https://your-domain.com
# Development example: http://localhost:3001
BETTER_AUTH_URL=http://localhost:3001

# Rate limiting configuration for authentication endpoints
# Optional: if not set, defaults to 60 second window with 30 max requests
# RATE_LIMIT_WINDOW: Time window in seconds for rate limiting (default: 60)
# RATE_LIMIT_MAX: Maximum number of requests allowed within the window (default: 30)
# Production example: RATE_LIMIT_WINDOW=60, RATE_LIMIT_MAX=30
# High-traffic example: RATE_LIMIT_WINDOW=60, RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=30

# Maximum concurrent sessions per user
# Optional: if not set, defaults to 5 sessions
# Production example: MAX_SESSIONS=5
# High-security example: MAX_SESSIONS=3
MAX_SESSIONS=5

# IP binding strictness for session security
# Optional: if not set, defaults to 'subnet' (matches /24 subnet)
# Options: 'exact' (exact IP match), 'subnet' (matches /24 subnet), 'disabled' (no IP binding)
# Production example: IP_BINDING_STRICTNESS=subnet
# High-security example: IP_BINDING_STRICTNESS=exact
# Mobile-friendly example: IP_BINDING_STRICTNESS=disabled
IP_BINDING_STRICTNESS=subnet

# Better Auth Infrastructure API key for audit logging and analytics
# Optional: if not set, audit logging will be disabled
# Get from: https://better-auth.com/dashboard
# Free tier available with limited features
BETTER_AUTH_API_KEY=your-api-key-here-optional

# Test database connection string for integration tests
# Optional: if not set, integration tests will be skipped
# Use a separate test database to avoid affecting development/production data
TEST_DATABASE_URL=postgresql://localhost:5432/suite_test

# Trusted origins for CSRF protection (Better Auth)
# Comma-separated list of allowed origins for authentication requests
# Defaults to localhost origins for development
# Production example: TRUSTED_ORIGINS=https://example.com,https://app.example.com
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:5173

# Google OAuth credentials for Google sign-in
# Optional: if not set, Google sign-in will be disabled
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID with redirect URI: http://localhost:3001/api/auth/callback/google (dev) or https://your-domain.com/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=your-google-client-id-here-optional
GOOGLE_CLIENT_SECRET=your-google-client-secret-here-optional

# GitHub OAuth credentials for GitHub sign-in
# Optional: if not set, GitHub sign-in will be disabled
# Get from: https://github.com/settings/developers
# Create OAuth App with redirect URI: http://localhost:3001/api/auth/callback/github (dev) or https://your-domain.com/api/auth/callback/github (prod)
# IMPORTANT: For GitHub Apps, enable "Email addresses: Read-Only" permission under Account Permissions
GITHUB_CLIENT_ID=your-github-client-id-here-optional
GITHUB_CLIENT_SECRET=your-github-client-secret-here-optional
